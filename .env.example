# Backend Configuration - Local Development
# DO NOT commit .env files to git - use .env.example as template

# Frontend URL for CORS (local development)
FRONTEND_URL=http://localhost:5173

# Comma-separated list of additional CORS origins (for localhost)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Database
DATABASE_URL=sqlite:///./skinlytix.db

# API Configuration
API_TITLE=Skinlytix API
API_VERSION=1.0

# Environment
ENVIRONMENT=development
